<% layout("/layouts/boilerplate") %>

<div class="row">
    <h2 class="col-6 offset-3 mt-2">Signup on <span class="signup-heading">StayQuest</span></h2>
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="username" class="form-label mb-0">Username</label>
                <input name="username" id="username" type="text" class="form-control" required>
                <div class="valid-feedback">Username looks good!</div>
                <div class="invalid-feedback">Please enter a Username</div>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label mb-0">Email</label>
                <input name="email" id="email" type="text" class="form-control" required>
                <div class="invalid-feedback">Please enter an Email</div>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label mb-0">Password</label>
                <input name="password" id="password" type="text" class="form-control" required>
                <div class="invalid-feedback">Please enter a Password</div>
            </div>
            <button class="btn btn-success signup-btn">SignUp</button>
        </form>
    </div>
</div>