<% layout("/layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="col show-page mt-1">
    <div class=" col-10 offset-2 mb-0 mt-1">
    <h3><%= listing.title %></h3>
    </div>
    <div class="card card-show col-6 mb-1"> 
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_img">
    <div class="card-body card-show-body">
        <p class="card-text mb-0 mt-1">
        <i>Owned by: <b><%= listing.owner.username %></b></i><br/>
        <%= listing.description %><br>
        <b>&#8377;<%= listing.price.toLocaleString("en-IN") %>/night</b><br>
        <%= listing.location %><br>
        <%= listing.country %><br>
        </p>
    </div>
    
    <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
        <div class="btns">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark offset-4 btn-1"> Edit </a>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-dark offset-4 btn-2">Delete</button>
        </form>
        </div>
    <% } %>
    </div>

    <div class="col-4 review  mb-2">
        <% if(currUser) { %>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class=" mt-2">
                <label for="rating" class="form-label mb-0">Rating</label>
                <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
            </div>

            <div class="mb-2">
                <label for="comment" class="form-label mb-0">Comments</label>
                <textarea name="review[comment]" id="comment" cols="20" rows="2" class="form-control" required></textarea>
                <div class="invalid-feedback">Please add some comments</div>
            </div>
            <button class="btn btn-outline-dark submit-btn">Submit</button>
        </form>
        <% } %>

        <hr/>    
        <% if(listing.reviews.length > 0)  { %>
        <div class="row">
        <h5>All reviews</h5>
        <% for(review of listing.reviews) { %>
            <div class="card review-card col-5 ms-3 mb-2">
                <div class="card-body">
                    <h6 class="card-title mb-2 mt-1">@<%= review.author.username %></h6>
                    <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                    <p class="card-text mb-1"><%= review.comment %></p>
                    <% if(currUser && review.author._id.equals(currUser._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-outline-dark mb-2 del-btn">Delete</button>
                    </form>
                    <% } %>
                </div>
            </div>
        <% } %>
        </div>
        <% } %>
    </div>

    <div class="col-6 offset-3 mb-2 mt-2">
        <h3>Where you'll be</h3>
        <div id="map"></div>
    </div>
</div>

<script src="/js/map.js"></script>