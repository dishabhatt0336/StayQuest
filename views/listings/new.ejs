<% layout("/layouts/boilerplate") %>

<div class="row mt-2">
    <div class="col-8 offset-2 ">
    <h3>Host your property!</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-2">
            <label for="title" class="form-label mb-1">Title</label>
        <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required>
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please enter a Title</div>
        </div>
        <div class="mb-2">
             <label for="description" class="form-label mb-1" >Description</label>
            <textarea name="listing[description]" placeholder="Describe your property here" type="text" class="form-control" required></textarea>
        <div class="invalid-feedback">Please enter a short description</div>
        </div>
        <div class="mb-2">
              <label for="image" class="form-label mb-1" >Upload Image</label>
            <input name="listing[image]" type="file" class="form-control" required>
        </div>

        <div class="row">
        <div class="mb-2 col-md-4">
              <label for="price" class="form-label mb-1" >Price</label>
            <input name="listing[price]" placeholder="1500" type="number" class="form-control" required>
        <div class="invalid-feedback">Please enter a valid Price</div>
        </div>
       <div class="mb-2 col-md-8">
         <label for="country" class="form-label mb-1" >Country</label>
         <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
        <div class="invalid-feedback">Please enter a valid Country</div>
        </div>
       </div>
       <div class="mb-2">
           <label for="location" class="form-label mb-1" >Location</label>
         <input name="listing[location]" placeholder="Udaipur, Rajasthan" type="text" class="form-control" required>
        <div class="invalid-feedback">Please enter a valid Location</div>
        </div>
       <br>
        <button class="btn btn-dark add-btn">Add</button>
        <br> <br> <br>
    </form>
</div>
</div>

